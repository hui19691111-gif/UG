<Window x:Class="ZhsmToolboxSettingsUI.BendFactorSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="批量修改折弯系数设置"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="批量修改折弯系数设置" FontSize="18" FontWeight="Bold" />
                <TextBlock x:Name="ConfigPathTextBlock" Foreground="#666666" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="恢复模板" Width="96" Margin="0,0,8,0" Click="RestoreTemplateButton_Click" />
                <Button Content="保存" Width="96" Margin="0,0,8,0" Click="SaveButton_Click" />
                <Button Content="关闭" Width="96" Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="规则表">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <GroupBox Grid.Row="0" Header="系数表路径" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CoefficientTablePathTextBox" Grid.Column="0" Margin="0,0,8,0" />
                            <Button Grid.Column="1" Content="导入系数表" MinWidth="110" Margin="0,0,8,0" Click="ImportCoefficientTableButton_Click" />
                            <Button Grid.Column="2" Content="导出系数表" MinWidth="110" Click="ExportCoefficientTableButton_Click" />
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0" Header="条件表" Margin="0,0,10,0">
                            <DataGrid x:Name="ConditionDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      ItemsSource="{Binding ConditionRows}"
                                      Margin="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="条件" Binding="{Binding ConditionKey, UpdateSourceTrigger=PropertyChanged}" Width="60" IsReadOnly="True" />
                                    <DataGridTextColumn Header="角度" Binding="{Binding AngleLabel, UpdateSourceTrigger=PropertyChanged}" Width="90" IsReadOnly="True" />
                                    <DataGridComboBoxColumn Header="小圆弧" SelectedValueBinding="{Binding SmallArcCode, UpdateSourceTrigger=PropertyChanged}" Width="90">
                                        <DataGridComboBoxColumn.ItemsSource>
                                            <x:Array Type="{x:Type sys:String}">
                                                <sys:String>Q1</sys:String>
                                                <sys:String>K1</sys:String>
                                                <sys:String>K2</sys:String>
                                            </x:Array>
                                        </DataGridComboBoxColumn.ItemsSource>
                                    </DataGridComboBoxColumn>
                                    <DataGridComboBoxColumn Header="大圆弧" SelectedValueBinding="{Binding LargeArcCode, UpdateSourceTrigger=PropertyChanged}" Width="90">
                                        <DataGridComboBoxColumn.ItemsSource>
                                            <x:Array Type="{x:Type sys:String}">
                                                <sys:String>K1</sys:String>
                                                <sys:String>K2</sys:String>
                                                <sys:String>Q1</sys:String>
                                            </x:Array>
                                        </DataGridComboBoxColumn.ItemsSource>
                                    </DataGridComboBoxColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="系数表">
                            <DataGrid x:Name="CoefficientDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="True"
                                      CanUserDeleteRows="True"
                                      ItemsSource="{Binding CoefficientRows}"
                                      Margin="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="材质" Binding="{Binding Material, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                                    <DataGridTextColumn Header="厚度" Binding="{Binding Thickness, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="70" />
                                    <DataGridTextColumn Header="Q1" Binding="{Binding Q1, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="Q2" Binding="{Binding Q2, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="Q3" Binding="{Binding Q3, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="K1" Binding="{Binding K1, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="K2" Binding="{Binding K2, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="K3" Binding="{Binding K3, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="A1" Binding="{Binding A1, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="A2" Binding="{Binding A2, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="A3" Binding="{Binding A3, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="R" Binding="{Binding R, UpdateSourceTrigger=PropertyChanged, StringFormat=0.###}" Width="60" />
                                    <DataGridTextColumn Header="F1" Binding="{Binding F1, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                                    <DataGridTextColumn Header="F2" Binding="{Binding F2, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="执行参数">
                <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="基础参数" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="AutoConvertToSheetmetalCheckBox" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="未识别到钣金体时自动转钣金" Margin="0,0,0,8" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="折向偏好" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <ComboBox x:Name="BaseFaceDirectionPreferenceComboBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8">
                                    <ComboBoxItem Content="相对主视面上折多优先" Tag="PreferUpBends" />
                                    <ComboBoxItem Content="相对主视面下折多优先" Tag="PreferDownBends" />
                                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="展开基面颜色" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="FixedFaceColorTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,12,8" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="扣除偏差(mm)" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="MaxDeductionDeviationTextBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,8" />
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="展开基面颜色使用 #RRGGBB，例如 #FFD400。" Foreground="#666666" TextWrapping="Wrap" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="大圆弧判定" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="UseAbsoluteRadiusThresholdCheckBox" Grid.Row="0" Grid.Column="0" Content="按绝对内R判定" Margin="0,0,8,8" />
                                <TextBox x:Name="AbsoluteRadiusThresholdTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,18,8" />
                                <CheckBox x:Name="UseRadiusThicknessRatioCheckBox" Grid.Row="0" Grid.Column="2" Content="按 R/T 判定" Margin="0,0,8,8" />
                                <TextBox x:Name="RadiusThicknessRatioThresholdTextBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="直角大R阈值" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="RightAngleRadiusThresholdTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,18,8" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="直角兜底K" VerticalAlignment="Center" Margin="0,0,8,8" />
                                <TextBox x:Name="RightAngleFallbackKFactorTextBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,8" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="锐角大R阈值" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="AcuteAngleRadiusThresholdTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,18,0" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="锐角兜底K" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="AcuteAngleFallbackKFactorTextBox" Grid.Row="2" Grid.Column="3" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="最小实体过滤">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="SkipSmallBodyCheckBox" Grid.Column="0" Content="启用最小实体过滤" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1" Text="长度阈值" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="MinBodyLengthTextBox" Grid.Column="2" Margin="0,0,18,0" />
                                <TextBlock Grid.Column="3" Text="宽度阈值" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="MinBodyWidthTextBox" Grid.Column="4" Margin="0,0,18,0" />
                                <TextBlock Grid.Column="5" Text="最大方向阈值" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="MaxBodyLengthTextBox" Grid.Column="6" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="StatusTextBlock" DockPanel.Dock="Left" Foreground="#666666" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="保存" Width="96" Margin="0,0,8,0" Click="SaveButton_Click" />
                <Button Content="关闭" Width="96" Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
