<Window x:Class="ZhsmToolboxSettingsUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="昭福工具设置"
        Width="760"
        Height="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="导出设置" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <CheckBox x:Name="ExportStepCheckBox" Content="导出 STEP" Margin="0,0,0,6" />
                            <CheckBox x:Name="StepPreserveAssemblyCheckBox" Content="STEP 保留装配结构" Margin="18,0,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <CheckBox x:Name="ExportIgesCheckBox" Content="导出 IGES" Margin="0,0,0,6" />
                            <CheckBox x:Name="IgesFlattenAssemblyCheckBox" Content="IGES 打平装配结构" Margin="18,0,0,0" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="多实体转装配" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="最小最大尺寸" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox x:Name="MultibodyMinBodyMaxDimensionTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="最小实体体积" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox x:Name="MultibodyMinBodyVolumeTextBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" />
                        <CheckBox x:Name="MultibodyAutoOpenCheckBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="执行后自动打开" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <CheckBox x:Name="MultibodyIncludeHiddenCheckBox" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="包含隐藏实体" VerticalAlignment="Center" Margin="0,0,0,0" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="装配转多实体" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <CheckBox x:Name="AssemblyToMultibodyAutoOpenCheckBox" Content="执行后自动打开" Margin="0,0,0,6" />
                            <CheckBox x:Name="AssemblyToMultibodyRecursiveCheckBox" Content="递归处理子装配" Margin="24,0,0,6" />
                            <CheckBox x:Name="AssemblyToMultibodyInheritDisplayCheckBox" Content="继承显示状态" Margin="24,0,0,6" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="批处理设置" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="长期折弯系数表、规则表、自动转钣金和实体过滤参数在这里维护。"
                                   VerticalAlignment="Center"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"
                                   Margin="0,0,12,0" />
                        <Button x:Name="OpenBendFactorSettingsButton"
                                Grid.Column="1"
                                Content="批量修改折弯系数设置"
                                MinWidth="190"
                                Padding="12,4"
                                Click="OpenBendFactorSettingsButton_Click" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="一键上色参数" Margin="0,0,0,8">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="OneClickColorShowPaletteEveryClickCheckBox"
                                      Content="每次点击显示窗体"
                                      VerticalAlignment="Center"
                                      Margin="0,0,24,0" />
                            <TextBlock Text="颜色方案" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="OneClickColorPaletteKindComboBox" Width="120">
                                <ComboBoxItem Content="浅色" Tag="Light" />
                                <ComboBoxItem Content="深色" Tag="Dark" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="上色范围" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorColorSheetMetalBodiesCheckBox" Content="钣金件上色" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorColorRemainingEntitiesCheckBox" Content="其余实体上色" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="重复实体" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorColorSameEntityGroupsCheckBox" Content="相同实体同色" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorColorMirroredSameEntityGroupsCheckBox" Content="镜像实体同色" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="装配与清理" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorOnlyTopLevelOccurrenceCheckBox" Content="装配体仅上色顶层" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorClearBodyColorCheckBox" Content="清理实体颜色" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorClearFaceColorCheckBox" Content="清理面颜色" Margin="0,0,0,6" />
                            <CheckBox x:Name="OneClickColorClearFeatureColorCheckBox" Content="清理特征颜色" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="3"
                                   Text="这些参数会读写 one_click_color_config.json；一键上色主命令仍负责执行上色和清理。"
                                   TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,10,0,0" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#666666" Text="设置将写回 toolbox.settings.json，并单独保存一键上色参数。" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="SaveButton" Content="保存" Width="96" Margin="0,0,8,0" Click="SaveButton_Click" />
                <Button x:Name="CancelButton" Content="取消" Width="96" Click="CancelButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
