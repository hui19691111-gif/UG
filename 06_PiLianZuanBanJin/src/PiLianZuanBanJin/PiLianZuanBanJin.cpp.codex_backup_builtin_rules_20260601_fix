        void RebuildTree()
        {
            if (tree_ == NULL)
            {
                return;
            }
            for (size_t i = allNodes_.size(); i > 0; --i)
            {
                try { tree_->DeleteNode(allNodes_[i - 1]); } catch (...) {}
            }
            nodeToRule_.clear();
            allNodes_.clear();
            selectedNode_ = NULL;

            for (size_t i = 0; i < config_.rules.size(); ++i)
            {
                std::string nodeText = config_.rules[i].name.empty() ? std::string(u8"规则") : config_.rules[i].name;
                Node* node = tree_->CreateNode(U8(nodeText));
                tree_->InsertNode(node, NULL, NULL, Tree::NodeInsertOptionAlwaysLast);
                allNodes_.push_back(node);
                FillNode(node, config_.rules[i]);
                nodeToRule_[node] = i;
            }
        }

        void FillNode(Node* node, const BendRule& rule)
        {
            SetNodeColumnText(node, ColumnEnabled, RuleBoolDisplay(rule.enabled));
            SetNodeColumnText(node, ColumnName, rule.name);
            SetNodeColumnText(node, ColumnMaterial, rule.material);
            SetNodeColumnText(node, ColumnAngleMin, OptionalRuleNumber(rule.hasAngleMin, rule.angleMin));
            SetNodeColumnText(node, ColumnAngleMax, OptionalRuleNumber(rule.hasAngleMax, rule.angleMax));
            SetNodeColumnText(node, ColumnThicknessMin, OptionalRuleNumber(rule.hasThicknessMin, rule.thicknessMin));
            SetNodeColumnText(node, ColumnThicknessMax, OptionalRuleNumber(rule.hasThicknessMax, rule.thicknessMax));
            SetNodeColumnText(node, ColumnRadiusMin, OptionalRuleNumber(rule.hasRadiusMin, rule.radiusMin));
            SetNodeColumnText(node, ColumnRadiusMax, OptionalRuleNumber(rule.hasRadiusMax, rule.radiusMax));
            SetNodeColumnText(node, ColumnMethod, RuleMethodDisplay(rule.method));
            SetNodeColumnText(node, ColumnValue, NumberText(rule.value));
            SetNodeColumnText(node, ColumnRadiusOverride, OptionalRuleNumber(rule.hasRadiusOverride, rule.radiusOverride));
            SetNodeColumnText(node, ColumnFallback, RuleBoolDisplay(rule.fallback));
            SetNodeColumnText(node, ColumnNote, rule.note);
        }

        bool IndexForNode(Node* node, size_t* index) const
        {
            std::map<Node*, size_t>::const_iterator it = nodeToRule_.find(node);
            if (it == nodeToRule_.end())
            {
                return false;
            }
            if (index != NULL)
            {
                *index = it->second;
            }
            return true;
        }

        bool ParseOptionalNumber(const std::string& text, bool* hasValue, double* value)
        {
            std::string trimmed = TrimCopy(text);
            if (trimmed.empty())
            {
                *hasValue = false;
                *value = 0.0;
                return true;
            }
            char* end = NULL;
            double parsed = std::strtod(trimmed.c_str(), &end);
            if (end == trimmed.c_str())
            {
                return false;
            }
            *hasValue = true;
            *value = parsed;
            return true;
        }

        bool ApplyTextToRule(BendRule& rule, int columnID, const std::string& text)
        {
            std::string value = TrimCopy(text);
            switch (columnID)
            {
            case ColumnEnabled: rule.enabled = RuleBoolValue(value, rule.enabled); return true;
            case ColumnName: rule.name = value; return true;
            case ColumnMaterial: rule.material = value; return true;
            case ColumnAngleMin: return ParseOptionalNumber(value, &rule.hasAngleMin, &rule.angleMin);
            case ColumnAngleMax: return ParseOptionalNumber(value, &rule.hasAngleMax, &rule.angleMax);
            case ColumnThicknessMin: return ParseOptionalNumber(value, &rule.hasThicknessMin, &rule.thicknessMin);
            case ColumnThicknessMax: return ParseOptionalNumber(value, &rule.hasThicknessMax, &rule.thicknessMax);
            case ColumnRadiusMin: return ParseOptionalNumber(value, &rule.hasRadiusMin, &rule.radiusMin);
            case ColumnRadiusMax: return ParseOptionalNumber(value, &rule.hasRadiusMax, &rule.radiusMax);
            case ColumnMethod: rule.method = value.find(u8"扣") != std::string::npos ? "Deduction" : "KFactor"; return true;
            case ColumnValue:
            {
                char* end = NULL;
                double parsed = std::strtod(value.c_str(), &end);
                if (end == value.c_str())
                {
                    return false;
                }
                rule.value = parsed;
                return true;
            }
            case ColumnRadiusOverride: return ParseOptionalNumber(value, &rule.hasRadiusOverride, &rule.radiusOverride);
            case ColumnFallback: rule.fallback = RuleBoolValue(value, rule.fallback); return true;
            case ColumnNote: rule.note = value; return true;
            default: return false;
            }
        }

        void AddRule()
        {
            BendRule rule;
            rule.name = u8"新规则";
            rule.material = u8"材质 <未指定>";
            config_.rules.push_back(rule);
