        void DeleteSelectedRule()
        {
            size_t index = 0;
            if (!IndexForNode(selectedNode_, &index) || index >= config_.rules.size())
            {
                return;
            }
            config_.rules.erase(config_.rules.begin() + static_cast<std::vector<BendRule>::difference_type>(index));
            RebuildTree();
        }

