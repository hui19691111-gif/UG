        UF_ATTR_info_t info;
        UF_ATTR_init_user_attribute_info(&info);
        logical hasAttribute = false;
        const int error = UF_ATTR_get_user_attribute_with_title_and_type(
            objectTag,
            title,
            UF_ATTR_string,
            UF_ATTR_NOT_ARRAY,
