    bool SaveRuleConfigToJson(const RuleConfig& config, std::string* pathOut, std::string* error)
    {
        std::string path = RulesJsonSavePath();
        std::string json = ReadAllText(path);
        std::string rulesJson = BuildRulesJsonArray(config.rules);
        if (json.empty())
        {
            json = std::string("{\n  \"LargeArcRuleSettings\":{\"UseAbsoluteRadiusThreshold\":true,\"AbsoluteRadiusThreshold\":") +
                NumberText(config.absoluteLargeArcRadius) +
                ",\"UseRadiusThicknessRatio\":false,\"RadiusThicknessRatioThreshold\":" +
                NumberText(config.ratioLargeArc) + "},\n  \"Rules\":" + rulesJson + "\n}\n";
        }
        else
        {
            size_t begin = 0;
            size_t end = 0;
            if (FindJsonArraySpan(json, "Rules", &begin, &end))
            {
                json.replace(begin, end - begin, rulesJson);
            }
            else
            {
                size_t insert = json.find_last_of('}');
                if (insert == std::string::npos)
                {
                    json = std::string("{\n  \"Rules\":") + rulesJson + "\n}\n";
                }
                else
                {
                    std::string prefix = json.substr(0, insert);
                    std::string suffix = json.substr(insert);
                    if (prefix.find_last_not_of(" \t\r\n") != std::string::npos && prefix[prefix.find_last_not_of(" \t\r\n")] != '{')
                    {
                        prefix += ",";
                    }
                    json = prefix + "\n  \"Rules\":" + rulesJson + "\n" + suffix;
                }
            }
        }

        std::ofstream file(path.c_str(), std::ios::out | std::ios::binary);
        if (!file)
        {
            if (error != NULL)
            {
                *error = u8"无法写入规则配置：" + path;
            }
            return false;
        }
        file.write(json.c_str(), static_cast<std::streamsize>(json.size()));
        if (pathOut != NULL)
        {
